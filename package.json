{
  "name": "monorepo-one",
  "version": "0.1.0",
  "private": true,
  "description": "Clean-slate high-grade monorepo foundation.",
  "type": "module",
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*",
    "tools/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "check": "bun run check:biome && bun run typecheck",
    "check:biome": "biome ci .",
    "dev": "turbo run dev",
    "format": "biome check --write .",
    "format:check": "biome ci .",
    "hooks:install": "lefthook install",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "test": "turbo run test",
    "typecheck": "tsc --build --pretty false",
    "verify": "bash tools/scripts/verify.sh",
    "verify:lefthook": "lefthook validate",
    "verify:moon": "moon --version",
    "verify:turbo": "turbo --version"
  },
  "engines": {
    "bun": ">=1.3.11"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@moonrepo/cli": "2.2.4",
    "lefthook": "2.1.6",
    "turbo": "2.9.14",
    "typescript": "6.0.3"
  }
}
